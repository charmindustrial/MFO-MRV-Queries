with offload_origins as(
    SELECT 
        consuming_order.order_number as offload_number,
        -- process.medium,
        pos.purchase_order_header_no,
        order_header_id,
        order_line_number as BOL_number,
        concat('https://charm-industrial.manufacturo.cloud/app/inventory/purchase-orders/(purchase:orders/', order_header_id,'/lines/',order_line_id,')') as purchase_order_link,
        trace.created_on as estimated_offload_date,
        product.code AS consumed_product_code,
        trace.lot_number AS offloaded_inventory_lot,
        trace.guid offloaded_inventory_trace,
        producing_trace.quantity as offload_work_order_total_qty,
        quantity_processed offloaded_quantity_kg,
        wscr.trace_guid as consumed_trace_guid,
        concat('https://charm-industrial.manufacturo.cloud/app/eworkin-plus-execution/order-execution/',consuming_order.guid,'/trace/',consuming_op.wip_trace_guid,'/') offload_order_link,
        poo.order_line_quantity_completed,
        consuming_order.actual_end_date,
        order_line_due_date,
        order_line_completed_on
    FROM [execution].[Wip_Step_Component_Record] wscr
    LEFT JOIN [execution].[Wip_Step_Component] wsc 
        ON wscr.wip_step_component_guid = wsc.guid
    LEFT JOIN [master].[Product] 
        ON wsc.product_guid = product.guid
    LEFT JOIN [execution].[Wip_Operation_Step] consuming_step 
        ON wsc.wip_operation_step_guid = consuming_step.guid
    LEFT JOIN [execution].[Wip_Operation] consuming_op 
        ON consuming_step.wip_operation_guid = consuming_op.guid
    LEFT JOIN [execution].[Wip_Order] consuming_order 
        ON consuming_op.wip_order_guid = consuming_order.guid
    -- Get the output trace from the sparging order
    LEFT JOIN [execution].[Wip_Trace] producing_trace 
        ON consuming_op.wip_trace_guid = producing_trace.guid
    LEFT JOIN [traceability].[Trace] trace 
        ON producing_trace.trace_guid = trace.guid
    LEFT JOIN [master].[Site] 
        ON consuming_order.site_guid = site.guid
    LEFT join genealogy.purchase_orders pos
        on pos.trace_id = wscr.trace_guid
    left join [external].purchase_order_overview poo
        on purchase_order_line_id = poo.order_line_id
    left join planning.Process_Translation process
        on consuming_order.process_guid = process.process_guid
    WHERE product.code IN ('bio_oil')
        AND site.code = 'CHARM_LOUISIANA'
        and process.medium like '%Offload%'
        and purchase_order_header_no <> 'AECN_LA_12.9'
    group by
        consuming_order.order_number,
        pos.purchase_order_header_no,
        order_header_id,
        order_line_number,
        concat('https://charm-industrial.manufacturo.cloud/app/inventory/purchase-orders/(purchase:orders/', order_header_id,'/lines/',order_line_id,')'),
        trace.created_on,
        product.code,
        trace.lot_number,
        trace.guid,
        producing_trace.quantity,
        quantity_processed,
        wscr.trace_guid,
        concat('https://charm-industrial.manufacturo.cloud/app/eworkin-plus-execution/order-execution/',consuming_order.guid,'/trace/',consuming_op.wip_trace_guid,'/'),
        poo.order_line_quantity_completed,
        consuming_order.actual_end_date,
        order_line_due_date,
        order_line_completed_on
),
injection_completion_dates as(
    select order_number,
    vals.value injection_completion_date
    from [external].data_collection_values vals
    left join [external].data_collection_details deets
        on vals.data_collection_id = deets.id
    left join [execution].[Wip_Operation] op
        on deets.operation_id =op.guid
    left join [execution].[Wip_Order] ordr
        on op.wip_order_guid = ordr.guid
    where deets.variable_code = 'icd' or deets.name = 'Injection Completion Date'
),
injection_ph as(
    select order_number,
    vals.value injection_ph
    from [external].data_collection_values vals
    left join [external].data_collection_details deets
        on vals.data_collection_id = deets.id
    left join [execution].[Wip_Operation] op
        on deets.operation_id =op.guid
    left join [execution].[Wip_Order] ordr
        on op.wip_order_guid = ordr.guid
    where variable_code = 'ph'
),
tote_attributes as (
    SELECT
    ordr.order_number,
    MAX(CASE WHEN deets.variable_code = 'toteWeight' THEN vals.value END) as gross_weight,
    MAX(CASE WHEN deets.variable_code = 'sectag' THEN vals.value END) as sectag,
    lot_number
    from [external].data_collection_values vals
    left join [external].data_collection_details deets
        on vals.data_collection_id = deets.id
    left join [execution].[Wip_Operation] op
        on deets.operation_id =op.guid
    left join [execution].[Wip_Order] ordr
        on op.wip_order_guid = ordr.guid
    LEFT JOIN master.[Site] site 
        ON ordr.site_guid = site.guid
    LEFT JOIN [execution].[Wip_Trace] wt
        ON op.wip_trace_guid = wt.guid
    LEFT JOIN [traceability].[Trace] 
        ON wt.trace_guid = trace.guid
    GROUP BY ordr.order_number, site.code, lot_number
)
SELECT 
        injection_order.order_number as injection_batch,
        product.code as injected_product,
        consumed_trace.lot_number as consumed_lot,
        ta.sectag as security_tag,
        oo.BOL_number,
        cast(SUM(wscr.quantity) as float) as quantity_consumed_in_injection,
        offloaded_quantity_kg,
        order_line_quantity_completed as origin_quantity_kg,
        -- case when product.code = 'bio_oil' then order_line_quantity_completed when product.code = 'Calciner' then inv.quantity_on_hand + cast(SUM(wscr.quantity) as float) end as origin_quantity_kg,
        order_line_completed_on,
        purchase_order_link,
        offload_order_link,
        cast(icd.injection_completion_date as date) as injection_completion_date,
        ip.injection_ph
    FROM [execution].[Wip_Step_Component_Record] wscr
    LEFT JOIN [execution].[Wip_Step_Component] wsc 
        ON wscr.wip_step_component_guid = wsc.guid
    LEFT JOIN [master].[Product] 
        ON wsc.product_guid = product.guid
    LEFT JOIN [execution].[Wip_Operation_Step] wos 
        ON wsc.wip_operation_step_guid = wos.guid
    LEFT JOIN [execution].[Wip_Operation] wop 
        ON wos.wip_operation_guid = wop.guid
    LEFT JOIN [execution].[Wip_Order] injection_order 
        ON wop.wip_order_guid = injection_order.guid
    LEFT JOIN [traceability].[Trace] consumed_trace 
        ON wscr.trace_guid = consumed_trace.guid
    LEFT JOIN [master].[Site] 
        ON injection_order.site_guid = site.guid
    left join planning.Process_Translation process
        on injection_order.process_guid = process.process_guid
    left join offload_origins oo
        on oo.offloaded_inventory_trace = consumed_trace.guid
    left join injection_ph ip
        on ip.order_number = injection_order.order_number
    left join injection_completion_dates icd
        on icd.order_number = injection_order.order_number
    left join inventory.[Inventory] inv
        on inv.trace_guid = consumed_trace.guid
    LEFT JOIN tote_attributes ta
        on consumed_trace.lot_number = ta.lot_number
    WHERE product.code IN ('bio_oil','Calciner','oily_fraction','aqueous_fraction')
        AND site.code = 'CHARM_LOUISIANA'
        and process.medium like '%injection%'
        and icd.injection_completion_date is not null
        and datepart(year, cast(icd.injection_completion_date as date)) >= '2026'
        -- and injection_order.order_number ='INJ-06-2026-W1_AECN'
    GROUP BY 
        injection_order.order_number,
        product.code,
        consumed_trace.lot_number,
        oo.BOL_number,
        purchase_order_link,
        estimated_offload_date,
        offloaded_quantity_kg,
        offload_order_link,
        order_line_quantity_completed,
        order_line_completed_on,
        icd.injection_completion_date,
        ip.injection_ph,
        -- inv.quantity_on_hand,
        ta.sectag
    order by
        cast(icd.injection_completion_date as date), injection_order.order_number